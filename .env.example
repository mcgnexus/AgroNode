# ─── AEMET OpenData ───
# Obtén tu API key en https://opendata.aemet.es/
AEMET_API_KEY="your-aemet-api-key-here"

# ─── Base de datos ───
# Neon PostgreSQL serverless (pooler connection)
DATABASE_URL="postgresql://neondb_owner:password@ep-xxx-xxx.us-east-2.aws.neon.tech/agronode?sslmode=require"

# ─── LLM ───
# DeepSeek API para el asistente agrícola
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Dispositivos IoT ───
# Secreto compartido para autenticar peticiones del ESP32
API_SECRET_ESP32="your-secret-token-here"

# ─── Webhook Bot ───
# Secreto compartido para verificar webhooks (usa hub.verify_token o x-webhook-secret)
WEBHOOK_SECRET="your-webhook-secret-here"

# Telegram Bot (obtenlo de @BotFather)
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# Twilio WhatsApp (https://console.twilio.com)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="+14155238886"

# ─── SIAR / RIA ───
# Token para la API SIAR (MAPA)
# Obtén tu token en https://servicio.mapa.gob.es/siarapi/
SIAR_TOKEN="your-siar-token-here"

# Token para la API RIA (IFAPA Junta de Andalucía)
# Base URL por defecto: https://www.juntadeandalucia.es/agriculturaypesca/ifapa/riaweb/api
RIA_TOKEN="your-ria-token-here"
# Modo de autenticación RIA: query | bearer | both
RIA_AUTH_MODE="query"

# ─── Aplicación ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

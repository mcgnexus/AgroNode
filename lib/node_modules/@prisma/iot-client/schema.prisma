generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/iot-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_IOT")
}

model nodes {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  node_code     String   @unique
  name          String?
  api_token     String
  location_name String?
  crop          String?
  active        Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  wifi_ssid     String?
  wifi_password String?

  sensor_readings sensor_readings[]

  @@index([node_code], map: "idx_nodes_node_code")
}

model sensor_readings {
  id                BigInt   @id @default(autoincrement())
  node_id           String   @db.Uuid
  measured_at       DateTime @default(now()) @db.Timestamptz(6)
  air_temp_c        Decimal? @db.Decimal(6, 2)
  air_humidity_pct  Decimal? @db.Decimal(6, 2)
  pressure_hpa      Decimal? @db.Decimal(7, 2)
  leaf_temp_c       Decimal? @db.Decimal(6, 2)
  soil_moisture_raw Int?
  soil_moisture_pct Decimal? @db.Decimal(6, 2)
  battery_v         Decimal? @db.Decimal(5, 2)
  rssi_dbm          Int?
  raw               Json?
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  nodes nodes @relation(fields: [node_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([node_id, measured_at(sort: Desc)], map: "idx_sensor_readings_node_time")
}
